/// 工厂函数：根据配置返回对应 Provider 实例。
///
/// # 参数
/// - `cfg`: {{Module}} 配置段
/// - `http_client`: 共享的 HTTP 客户端（必须共享以复用连接池）
///
/// # 错误
/// - `CoreError::Config`: 配置错误（如 API key 缺失）
pub fn build_provider(
    cfg: &crate::config::{{Module}}Config,
    http_client: reqwest::Client,
) -> Result<Box<dyn {{TraitName}}>, CoreError> {
    match cfg.provider.as_str() {
        "{{provider_id_default}}" => Ok(Box::new({{ProviderImplName}}::new(
            http_client,
            cfg.{{provider_id_default}}.clone(),
        )?)),
        other => Err(CoreError::Config(format!(
            "unknown {{module}} provider: {}",
            other
        ))),
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    /// Mock 实现，用于测试 Orchestrator 与 {{TraitName}} 的解耦。
    struct Mock{{TraitName}};

    #[async_trait]
    impl {{TraitName}} for Mock{{TraitName}} {
        fn id(&self) -> {{ProviderId}} {
            {{ProviderId}}::from_static("mock")
        }
    }

    #[test]
    fn mock_can_be_boxed() {
        let provider: Box<dyn {{TraitName}}> = Box::new(Mock{{TraitName}});
        assert_eq!(provider.id().as_str(), "mock");
    }

    #[test]
    fn build_provider_rejects_unknown() {
        let cfg = crate::config::{{Module}}Config {
            provider: "nonexistent".into(),
            ..Default::default()
        };
        let result = build_provider(&cfg, reqwest::Client::new());
        assert!(result.is_err());
    }
}
