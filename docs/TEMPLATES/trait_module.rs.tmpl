/// {{TraitName}} 抽象。
///
/// 所有 {{Module}} Provider 必须实现此 trait。
///
/// # 实现者须知
///
/// - 实现必须是 `Send + Sync`（trait 已声明）
/// - 异步方法内部若调用 CPU 密集操作，请用 `spawn_blocking`
/// - 错误统一返回 `CoreError`
///
/// # 调用方须知
///
/// - 实例通过 [`build_provider`] 工厂函数构造
/// - 注入到 `Arc<dyn {{TraitName}}>` 持有
#[async_trait]
pub trait {{TraitName}}: Send + Sync {
    /// 返回 Provider 唯一标识（用于日志、配置路由）。
    fn id(&self) -> {{ProviderId}};

    // TODO: 在此声明 trait 方法
