{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SnapText",
  "version": "0.1.3",
  "identifier": "com.snaptext.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SnapText",
        "url": "index.html#/home",
        "width": 560,
        "height": 480,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$LOCALDATA/com.snaptext.app/tmp/**", "$APPDATA/com.snaptext.app/tmp/**", "$APPCONFIG/com.snaptext.app/tmp/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
